{
  "branches": [
    "main",
    {"name": "rc", "prerelease": "rc"},
    {"name": "beta", "prerelease": "beta"},
    {"name": "release/skill-validation", "prerelease": "cd"}
  ],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    ["@semantic-release/github", {
      "successCommentCondition": false,
      "releasedLabels": false,
      "failTitle": false,
      "failComment": false
    }]
  ]
}
