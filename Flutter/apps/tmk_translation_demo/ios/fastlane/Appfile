app_identifier("co.timekettle.translation.sample")
apple_id(ENV["APPLE_ID"]) if ENV["APPLE_ID"]

# 使用 App Store Connect API（如果配置了）
if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"]
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_content: ENV["ASC_PRIVATE_KEY"]
  )
end
