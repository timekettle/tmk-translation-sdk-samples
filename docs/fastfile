require 'shellwords'

# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

# 定义全局变量
$scheme = "Timekettle2022" # 修改当前为自己工程的scheme
$required_env_vars = ['MATCH_GIT_TOKEN', 'MATCH_PASSWORD', 'ASC_ISSUER_ID', 'ASC_KEY_ID', 'ASC_PRIVATE_KEY']

platform :ios do
  # 获取 app identifier 的辅助方法
  def get_app_identifier
    CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
  end

  # 通过 match 结果动态注入 profile，避免依赖 project.pbxproj 中写死的名称
  def resolve_signing_overrides(app_id:, type:)
    normalized_app_id = app_id.to_s.gsub(/[^a-zA-Z0-9]/, '_')
    profile_uuid = ENV["sigh_#{normalized_app_id}_#{type}"]
    profile_mapping = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING] || {}
    profile_name = profile_mapping[app_id]

    xcargs = []
    if profile_name.to_s.empty?
      xcargs << "PROVISIONING_PROFILE_SPECIFIER="
    else
      xcargs << "PROVISIONING_PROFILE_SPECIFIER=#{Shellwords.escape(profile_name)}"
    end
    xcargs << "PROVISIONING_PROFILE=#{Shellwords.escape(profile_uuid)}" unless profile_uuid.to_s.empty?

    {
      profile_name: profile_name,
      xcargs: xcargs.join(' ')
    }
  end
  
  # 验证环境变量和先决条件
  lane :verify_environment do |options|
    match_type = options[:type] || 'adhoc'
    
    UI.header("🔍 验证环境配置")
    
    # 检查必需的环境变量
    missing_vars = $required_env_vars.select { |var| ENV[var].nil? || ENV[var].empty? }
    
    if missing_vars.any?
      UI.error("❌ 缺少以下环境变量: #{missing_vars.join(', ')}")
      UI.error("请在 GitHub Secrets 或本地环境中设置这些变量")
      UI.user_error!("环境变量配置不完整")
    end
    
    app_id = get_app_identifier
    UI.success("✅ 环境变量配置完整")
    UI.message("📱 App Identifier: #{app_id}")
    UI.message("🔐 Match Type: #{match_type}")
    UI.message("🌿 Git Branch: main")
    UI.message("🔒 Readonly Mode: #{ENV['CI'] ? 'true (CI environment)' : 'false (local)'}")
    
    if ENV['CI']
      UI.important("⚠️  在 CI 环境中运行，证书必须预先存在于 ios-certificates 仓库")
      UI.important("如果遇到证书未找到错误，请先运行: fastlane setup_certificates type:#{match_type} (在本地)")
    end
  end
  
  lane :pre_build do |options|
    # 设置 CI 环境
    setup_ci if ENV['CI']

    # 从传入的选项中获取 in_house 参数
    is_adhoc = options[:is_adhoc] || false
    
    # 连接 appstore 获取 api_key
    if is_adhoc
      api_key = app_store_connect_api_key(
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_id: ENV["ASC_KEY_ID"],
        key_content: ENV["ASC_PRIVATE_KEY"],
        is_key_content_base64: true,
        in_house: false
      )
    else
      api_key = app_store_connect_api_key(
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_id: ENV["ASC_KEY_ID"],
        key_content: ENV["ASC_PRIVATE_KEY"],
        is_key_content_base64: true
      )
    end
  end

  lane :post_build do
    # 获取构建生成的 IPA 文件路径
    ipa_path = lane_context[SharedValues::IPA_OUTPUT_PATH]
    # 只在 CI 环境中设置 GITHUB_ENV
    if ENV['CI'] && ENV['GITHUB_ENV']
      sh("echo 'APK_PATH=#{ipa_path}' >> $GITHUB_ENV")
    end
    UI.success("IPA 文件路径: #{ipa_path}")
  end

  desc "Build and Upload to Pyger"
  lane :beta do
    # 验证环境配置
    verify_environment(type: 'adhoc')
    
    pre_build(is_adhoc: true)

    # 匹配证书和配置文件 https://docs.fastlane.tools/actions/match/
    api_key = lane_context[SharedValues::APP_STORE_CONNECT_API_KEY]
    
    # 显式指定 app_identifier 以确保 match 使用正确的标识符
    app_id = get_app_identifier
    UI.message("📱 App Identifier: #{app_id}")
    UI.message("🔐 Match Type: adhoc")
    UI.message("🌿 Git Branch: main")
    
    match(
      type: 'adhoc', # 默认: development, 可选: appstore, adhoc, enterprise, development
      app_identifier: app_id,
      api_key: api_key,
      git_url: "https://#{ENV["MATCH_GIT_TOKEN"]}@github.com/timekettle/ios-certificates.git",
      git_branch: "main",
      readonly: true, # 总是 readonly，证书应通过 setup_certificates lane 创建
      verbose: true, # 启用详细日志以便调试
    )

    signing = resolve_signing_overrides(app_id: app_id, type: 'adhoc')
    UI.message("🔐 使用动态签名配置: #{signing[:profile_name] || 'UUID only'}")

    build_options = {
      scheme: $scheme, # 替换为你的 Xcode scheme 名称
      export_method: "ad-hoc", # 用于导出存档的方法。有效值为：app-store、validation、ad-hoc、package、enterprise、development、developer-id 和 mac-application
      configuration: "Adhoc",
      output_directory: "./build", # 输出目录
      xcargs: signing[:xcargs],
    }
    unless signing[:profile_name].to_s.empty?
      build_options[:export_options] = {
        provisioningProfiles: {
          app_id => signing[:profile_name]
        }
      }
    end

    # 构建应用 https://docs.fastlane.tools/actions/build_app/#build_app
    build_app(build_options)

    post_build
  end

  desc "Upload to TestFlight / ASC"
  lane :beta_and_upload_to_testflight do
    # 验证环境配置
    verify_environment(type: 'appstore')
    
    pre_build(is_adhoc: false)

    # 匹配证书和配置文件 https://docs.fastlane.tools/actions/match/
    api_key = lane_context[SharedValues::APP_STORE_CONNECT_API_KEY]
    
    # 显式指定 app_identifier 以确保 match 使用正确的标识符
    app_id = get_app_identifier
    UI.message("📱 App Identifier: #{app_id}")
    UI.message("🔐 Match Type: appstore")
    UI.message("🌿 Git Branch: main")
    
    match(
      type: 'appstore', # 默认: development, 可选: appstore, adhoc, enterprise, development
      app_identifier: app_id,
      api_key: api_key,
      git_url: "https://#{ENV["MATCH_GIT_TOKEN"]}@github.com/timekettle/ios-certificates.git",
      git_branch: "main",
      readonly: true, # 总是 readonly，证书应通过 setup_certificates lane 创建
      verbose: true, # 启用详细日志以便调试
    )

    signing = resolve_signing_overrides(app_id: app_id, type: 'appstore')
    UI.message("🔐 使用动态签名配置: #{signing[:profile_name] || 'UUID only'}")

    build_options = {
      scheme: $scheme, # 替换为你的 Xcode scheme 名称
      export_method: "app-store", # 用于导出存档的方法。有效值为：app-store、validation、ad-hoc、package、enterprise、development、developer-id 和 mac-application
      configuration: "Release", # App Store builds 使用 Release 配置
      output_directory: "./build", # 输出目录
      xcargs: signing[:xcargs],
    }
    unless signing[:profile_name].to_s.empty?
      build_options[:export_options] = {
        provisioningProfiles: {
          app_id => signing[:profile_name]
        }
      }
    end

    # 构建应用 https://docs.fastlane.tools/actions/build_app/#build_app
    build_app(build_options)

    post_build

    # 上传 appstore
    deliver(
        api_key: api_key,
        skip_screenshots: true,
        skip_metadata: true,
        skip_app_version_update: true,
        force: true, # skips verification of HTML preview file (since this will be run from a CI machine)
        run_precheck_before_submit: false # not supported through ASC API yet
    )
  end
  
  desc "设置证书 - 在本地运行以创建和上传证书到 ios-certificates 仓库"
  desc "Setup Certificates - Run locally to create and upload certificates to ios-certificates repo"
  lane :setup_certificates do |options|
    cert_type = options[:type] || 'adhoc'
    
    UI.header("🔐 设置 #{cert_type} 证书")
    
    if ENV['CI']
      UI.user_error!("❌ 此操作不能在 CI 环境中运行。请在本地 Mac 上运行。")
    end
    
    # 检查必需的环境变量
    missing_vars = $required_env_vars.select { |var| ENV[var].nil? || ENV[var].empty? }
    
    if missing_vars.any?
      UI.error("❌ 缺少以下环境变量: #{missing_vars.join(', ')}")
      UI.message("\n请设置环境变量:")
      missing_vars.each do |var|
        UI.message("  export #{var}='your_value_here'")
      end
      UI.user_error!("环境变量配置不完整")
    end
    
    app_id = get_app_identifier
    
    UI.success("✅ 环境变量配置完整")
    UI.message("📱 App Identifier: #{app_id}")
    UI.message("🔐 Certificate Type: #{cert_type}")
    UI.message("")
    UI.important("此操作将:")
    UI.message("  1. 在 Apple Developer Portal 创建证书和配置文件")
    UI.message("  2. 将它们加密并存储到 ios-certificates 仓库")
    UI.message("  3. 安装到你的本地 keychain")
    UI.message("")
    
    # 连接 App Store Connect
    api_key = app_store_connect_api_key(
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_id: ENV["ASC_KEY_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: true
    )
    
    # 创建并上传证书
    match(
      type: cert_type,
      app_identifier: app_id,
      api_key: api_key,
      git_url: "https://#{ENV["MATCH_GIT_TOKEN"]}@github.com/timekettle/ios-certificates.git",
      git_branch: "main",
      readonly: false, # 允许创建新证书
      force_for_new_devices: true, # 为新设备更新配置文件
    )
    
    UI.success("✅ 证书设置完成!")
    UI.success("现在可以在 CI 中运行构建了")
  end
end