source 'https://cdn.cocoapods.org/'
# 正式版 podspec 发布在公开 spec 仓库的 main 分支(默认分支)。
source 'https://github.com/timekettle/TmkTranslationSDK-iOS.git'

platform :ios, '15.0'

target 'SDKDemo' do
  # Comment the next line if you don't want to use dynamic frameworks
  use_frameworks!

  # Pods for SDKDemo
  # 1.2.0-rc3 为预发布版,其 podspec 仅推送到公开 spec 仓库的 rc 分支,
  # 不在默认分支 main 上;而 CocoaPods 的 source 只读取默认分支,无法解析到该版本。
  # 因此这里用 :podspec 直接锁定 rc 分支上该版本 podspec 的 raw 地址。
  # 升级到正式版后,改回 pod 'TmkTranslationSDK', 'X.Y.Z' 即可(走上面的 source)。
  pod 'TmkTranslationSDK', :podspec => 'https://raw.githubusercontent.com/timekettle/TmkTranslationSDK-iOS/rc/Specs/TmkTranslationSDK/1.2.0-rc3/TmkTranslationSDK.podspec'
  pod 'SnapKit'

  target 'SDKDemoTests' do
    inherit! :search_paths
    # Pods for testing
  end

  target 'SDKDemoUITests' do
    # Pods for testing
  end

end
