// Copy this file to LocalSecrets.xcconfig and replace the placeholders with your real credentials.
// Use raw values only. Do not wrap the values in quotes, apostrophes, or angle brackets.
// Correct: TMK_SAMPLE_APP_ID = 73318e8ad
// Incorrect: TMK_SAMPLE_APP_ID = "73318e8ad" or '73318e8ad'
// Do not commit LocalSecrets.xcconfig.

TMK_SAMPLE_APP_ID = your_app_id
TMK_SAMPLE_APP_SECRET = your_app_secret
